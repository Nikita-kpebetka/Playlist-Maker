<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <LinearLayout
        android:layout_height="match_parent"
        android:layout_width="match_parent"
        style="@style/Settings_screen_template">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:gravity="center_vertical"
            android:paddingStart="@dimen/standard_margin">

            <ImageView
                android:id="@+id/backButton"
                android:layout_width="@dimen/button_icon_size"
                android:layout_height="@dimen/button_icon_size"
                android:src="@drawable/ic_arrow_back"
                app:tint="@color/black"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:scaleType="center"
                android:padding="48dp"/>

            <TextView
                style="@style/Settings_text"
                android:layout_marginStart="@dimen/button_icon_padding"
                android:text="@string/Settings"
                android:textSize="@dimen/header_button_text_size"
                android:fontFamily="@font/ys_display_bold"
                android:textStyle="bold" />
        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/settings_item_height"
            android:layout_marginTop="24dp"
            android:paddingHorizontal="@dimen/standard_margin">

            <TextView
                style="@style/Settings_text"
                android:text="@string/Dark_theme" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/themeSwitch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end|center_vertical"
                app:thumbTint="@color/white"
                app:trackTint="#00D6C3" />
        </FrameLayout>

        <FrameLayout
            android:id="@+id/shareApp"
            style="@style/Settings_button_template">

            <TextView
                style="@style/Settings_text"
                android:text="@string/Share_app" />

            <ImageView
                android:layout_gravity="center_vertical|end"
                android:src="@drawable/ic_share"
                style="@style/Settings_icon"/>
        </FrameLayout>

        <FrameLayout
            android:id="@+id/writeSupport"
            style="@style/Settings_button_template">

            <TextView
                style="@style/Settings_text"
                android:text="@string/Write_to_support" />

            <ImageView
                android:layout_gravity="center_vertical|end"
                android:src="@drawable/ic_support"
                style="@style/Settings_icon"/>
        </FrameLayout>

        <FrameLayout
            android:id="@+id/userAgreement"
            style="@style/Settings_button_template">

            <TextView
                style="@style/Settings_text"
                android:text="@string/User_Agreement" />

            <ImageView
                android:layout_gravity="center_vertical|end"
                android:src="@drawable/ic_arrow_forward"
                style="@style/Settings_icon"/>
        </FrameLayout>


    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>