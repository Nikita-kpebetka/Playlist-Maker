<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".SearchActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        style="@style/Settings_screen_template">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:gravity="center_vertical"
            android:paddingStart="@dimen/standard_margin">

            <ImageView
                android:id="@+id/backButton"
                android:layout_width="@dimen/button_icon_size"
                android:layout_height="@dimen/button_icon_size"
                android:src="@drawable/ic_arrow_back"
                app:tint="@color/black"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:scaleType="center"
                android:padding="48dp"/>

            <TextView
                style="@style/Settings_text"
                android:layout_marginStart="12dp"
                android:text="@string/Search"
                android:textSize="@dimen/header_button_text_size"
                android:fontFamily="@font/ys_display_bold"
                android:textStyle="bold" />
        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="8dp">

            <EditText
                android:id="@+id/searchEditText"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/light_gray"
                android:drawableStart="@drawable/ic_magnifier"
                android:drawablePadding="8dp"
                android:drawableTint="@color/text_gray"
                android:hint="@string/Search"
                android:inputType="text"
                android:maxLines="1"
                android:paddingStart="12dp"
                android:paddingRight="@dimen/button_radius_search"
                android:textColor="@color/text_gray"
                android:textColorHint="@color/text_gray"
                android:textSize="16sp" />

            <ImageView
                android:id="@+id/clearButton"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="end|center_vertical"
                android:layout_marginEnd="8dp"
                android:src="@drawable/ic_clear"
                android:visibility="gone"
                app:tint="@color/text_gray" />
        </FrameLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>