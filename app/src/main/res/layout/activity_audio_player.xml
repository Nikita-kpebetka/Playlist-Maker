<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    style="@style/Settings_screen_template">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="28dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/backButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:navigationIconTint="@color/black"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <ImageView
            android:id="@+id/ivAlbumCover"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="24dp"
            android:scaleType="centerCrop"
            android:clipToOutline="true"
            android:background="@drawable/vector"
            app:layout_constraintDimensionRatio="1:1"
            app:layout_constraintTop_toBottomOf="@id/backButton"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvTrackName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="24dp"
            android:fontFamily="@font/ys_display_medium"
            android:textSize="22sp"
            app:layout_constraintTop_toBottomOf="@id/ivAlbumCover"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:text="ПРООООООстоооооо_ОЧень_Длинный текст, для ПРОВЕРКИ " />

        <TextView
            android:id="@+id/tvArtistName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="12dp"
            android:fontFamily="@font/ys_display_regular"
            android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@id/tvTrackName"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:text="ПРООООООстоооооо_ОЧень_Длинный текст, для ПРОВЕРКИ "/>

        <ImageView
            android:id="@+id/btnAddToPlaylist"
            android:layout_width="51dp"
            android:layout_height="51dp"
            android:layout_marginStart="24dp"
            android:src="@drawable/ic_add_to_playlist1"
            app:layout_constraintTop_toTopOf="@id/btnPlay"
            app:layout_constraintBottom_toBottomOf="@id/btnPlay"
            app:layout_constraintStart_toStartOf="parent" />

        <ImageView
            android:id="@+id/btnPlay"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_marginTop="30dp"
            android:src="@drawable/ic_play"
            app:tint="@color/black"
            app:layout_constraintTop_toBottomOf="@id/tvArtistName"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <ImageView
            android:id="@+id/btnAddToFavorite"
            android:layout_width="51dp"
            android:layout_height="51dp"
            android:layout_marginEnd="24dp"
            android:src="@drawable/ic_favorite1"
            app:layout_constraintTop_toTopOf="@id/btnPlay"
            app:layout_constraintBottom_toBottomOf="@id/btnPlay"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvPlayTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:fontFamily="@font/ys_display_medium"
            android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@id/btnPlay"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:text="00:00"
            tools:text="ПРООООООстоооооо_ОЧень_Длинный текст, для ПРОВЕРКИ " />

        <TextView
            android:id="@+id/lblTrackTimeTitle"
            style="@style/Label_title"
            android:text="@string/Duration"
            android:layout_marginTop="30dp"
            app:layout_constraintTop_toBottomOf="@id/tvPlayTime"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/tvTrackTimeValue"
            style="@style/Label_value"
            android:gravity="end"
            android:layout_marginStart="16dp"
            app:layout_constraintBaseline_toBaselineOf="@id/lblTrackTimeTitle"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/lblTrackTimeTitle"
            tools:text="ПРООООООстоооооо_ОЧень_Длинный текст, для ПРОВЕРКИ " />

        <TextView
            android:id="@+id/lblCollectionTitle"
            style="@style/Label_title"
            android:text="@string/Album"
            app:layout_constraintTop_toBottomOf="@id/lblTrackTimeTitle"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/tvCollectionValue"
            style="@style/Label_value"
            android:gravity="end"
            android:layout_marginStart="45dp"
            app:layout_constraintBaseline_toBaselineOf="@id/lblCollectionTitle"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/lblCollectionTitle"
            tools:text="ПРООООООстоооооо_ОЧень_Длинный текст, для ПРОВЕРКИ " />

        <TextView
            android:id="@+id/lblReleaseDateTitle"
            style="@style/Label_title"
            android:text="@string/Year"
            app:layout_constraintTop_toBottomOf="@id/lblCollectionTitle"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/tvReleaseDateValue"
            style="@style/Label_value"
            app:layout_constraintBaseline_toBaselineOf="@id/lblReleaseDateTitle"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/lblReleaseDateTitle"
            tools:text="ПРООООООстоооооо_ОЧень_Длинный текст, для ПРОВЕРКИ " />

        <TextView
            android:id="@+id/lblGenreTitle"
            style="@style/Label_title"
            android:text="@string/Genre"
            app:layout_constraintTop_toBottomOf="@id/lblReleaseDateTitle"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/tvGenreValue"
            style="@style/Label_value"
            android:layout_marginStart="16dp"
            app:layout_constraintBaseline_toBaselineOf="@id/lblGenreTitle"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/lblGenreTitle"
            tools:text="ПРООООООстоооооо_ОЧень_Длинный текст, для ПРОВЕРКИ " />

        <TextView
            android:id="@+id/lblCountryTitle"
            style="@style/Label_title"
            android:text="@string/Country"
            app:layout_constraintTop_toBottomOf="@id/lblGenreTitle"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/tvCountryValue"
            style="@style/Label_value"
            app:layout_constraintBaseline_toBaselineOf="@id/lblCountryTitle"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/lblCountryTitle"
            tools:text="ПРООООООстоооооо_ОЧень_Длинный текст, для ПРОВЕРКИ " />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>